{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Yarp": "Information"
    }
  },
  "AllowedHosts": "*",
  "Seq": {
    "ServerUrl": "http://localhost:5341"
  },

  "ReverseProxy": {
    "Routes": {
      "catalog-route": {
        "ClusterId": "catalog-cluster",
        "Match": { "Path": "/catalog/{**catch-all}" },
        "Transforms": [ { "PathRemovePrefix": "/catalog" } ]
      },
      "inventory-route": {
        "ClusterId": "inventory-cluster",
        "Match": { "Path": "/inventory/{**catch-all}" },
        "Transforms": [ { "PathRemovePrefix": "/inventory" } ]
      },
      "orders-route": {
        "ClusterId": "orders-cluster",
        "Match": { "Path": "/orders/{**catch-all}" },
        "Transforms": [ { "PathRemovePrefix": "/orders" } ]
      },
      "notifications-route": {
        "ClusterId": "notifications-cluster",
        "Match": { "Path": "/notifications/{**catch-all}" },
        "Transforms": [ { "PathRemovePrefix": "/notifications" } ]
      },
      "bff-route": {
        "ClusterId": "bff-cluster",
        "Match": { "Path": "/bff/{**catch-all}" },
        "Transforms": [ { "PathRemovePrefix": "/bff" } ]
      }
    },

    "Clusters": {
      "catalog-cluster": {
        "Destinations": {
          "lb": { "Address": "http://catalog-lb:80/" }
        }
      },
      "inventory-cluster": {
        "Destinations": {
          "d1": { "Address": "http://inventory:8080/" }
        }
      },
      "orders-cluster": {
        "Destinations": {
          "d1": { "Address": "http://order:8080/" }
        }
      },
      "notifications-cluster": {
        "Destinations": {
          "d1": { "Address": "http://notification:8080/" }
        }
      },
      "bff-cluster": {
        "Destinations": {
          "d1": { "Address": "http://webbff:8080/" }
        }
      }
    }
  }
}
